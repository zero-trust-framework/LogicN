// Style 1: canonical line comment (TypeScript/JS devs)

;; Style 2: assembly/Lisp line comment

/*
  Style 3: block comment
  spans multiple lines
  no nesting needed
*/

pure flow addNumbers(a: Int, b: Int) -> Int  // inline line comment
contract {
  intent "Add two numbers"  ;; inline assembly comment
  effects {}
  /* block comment inside contract */
}
{
  let result = a + b;  // trailing semicolon — optional, silently accepted
  return result        ;; no semicolon — also fine
}

/*
  Governance note:
  This flow has no effects declared.
  V_DPM = 0x00 — no capability bits required.
  Passes: LLN-CAP-001, LLN-GOV-004, LLN-INV-004
*/
pure flow multiplyNumbers(x: Int, y: Int) -> Int
contract {
  intent "Multiply two numbers"
  effects {}
}
{
  return x * y;
}
