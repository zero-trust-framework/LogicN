// Task #90: policy {} State Mutation Governance
// Demonstrates governed mut variable transitions
//
// The `policy {}` block inside `contract {}` declares permitted transitions
// on `mut` variables. Two constraint types are supported:
//
//   varName: only_decrease     — monotonically-decreasing (like V_DPM)
//   varName: max_change N      — max change per call
//   requires effect.name       — mutation triggers a required effect
//
// These are verified by the governance verifier (FUNGI-MUTATION-001/002).

secure flow decrement(startCount: Int, amount: Int) -> Int
contract {
  intent "Decrement a counter with mutation governance"
  effects { audit.write }
  invariant {
    ensure startCount >= 0
    ensure amount > 0
    ensure amount <= 100
  }
  policy {
    counter: only_decrease
    counter: max_change 100
    requires audit.write
  }
}
{
  trap amount > 100 : ERR_DELTA_EXCEEDS_POLICY
  trap startCount - amount < 0 : ERR_WOULD_GO_NEGATIVE
  mut counter: Int = startCount
  counter = counter - amount
  return counter
}
