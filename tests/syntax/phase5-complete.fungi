/*
 * Phase 5 completion test
 * Tests all Phase 5 features together: step, view(), governed, trap, evict
 */

import plugin assimilate "./plugins/payment-stub.fungi" as Pay {
  contract {
    intent "Payment gateway — hot-loaded plugin"
    access {
      grant network.outbound
      grant audit.write
    }
  }
}

guard PaymentGuard {
  permitted_effects {
    network.outbound
    audit.write
    database.write
  }
  emergency {
    on invariant_failure {
      deny network.outbound
      quarantine
    }
  }
}

static MAX_PAYMENT_AMOUNT = 1000000
static MIN_PAYMENT_AMOUNT = 1

bitfield PaymentBits {
  network:  0
  audit:    3
  database: 4
}

governed floor_3 flow validatePayment(amount: Int) -> Bool
contract [conforms_to: PaymentGuard] {
  intent "Validate payment amount in the Proof Zone"
  effects { audit.write }
  invariant {
    ensure amount > 0
    ensure amount <= 1000000
  }
}
{
  ;; Tower validates dag_edge_valid (bit 8) before this flow dispatches
  trap amount <= 0 : ERR_ZERO_AMOUNT          ;; fires → FUNGI-INV-000 AuditEvent
  trap amount > 1000000 : ERR_LIMIT           ;; literal mirrors MAX_PAYMENT_AMOUNT static
  return true
}

secure flow processWithStep(amount: Int) -> Result<Bool, Error>
contract {
  intent "Process a payment using step DWI isolation"
  effects { allow network.outbound, allow audit.write }
}
{
  trap amount <= 1 : ERR_TOO_SMALL            ;; literal mirrors MIN_PAYMENT_AMOUNT static

  ;; step creates a DWI isolate → handleTrap → AuditEvent on any fault
  let valid = step validatePayment(amount)
  return Ok(valid)
}
