;; Foundation test: gate {} verifier + access {} grant enforcement

guard AdminGuard {
  permitted_effects {
    database.write
    audit.write
  }
}

;; gate with known guard — should pass LLN-GATE-001
gate(AdminGuard) {
  secure flow adminAction(userId: String) -> Bool
  contract {
    intent "Admin-only action"
    effects { database.write, audit.write }
  }
  {
    trap userId == "" : ERR_EMPTY_USER
    return true
  }
}

;; flow with access {} — valid grants consistent with effects
secure flow processData(payload: String) -> Result<Bool, Error>
contract {
  intent "Process data with explicit access negotiation"
  effects { allow database.write, allow audit.write }
}
access {
  grant database.write    ;; callers need database.write to invoke this
  grant audit.write       ;; callers need audit.write
}
{
  return Ok(true)
}
