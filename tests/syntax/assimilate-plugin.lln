/* Assimilate plugin test — Hot-Code Residency directive */

import plugin assimilate "./plugins/payments.lln" as Pay {
  contract {
    intent "Payment gateway — pre-compiled, always-hot, stateless per call"
    access {
      grant network.outbound      ;; V_DPM bit 0 pre-set at boot
      grant audit.write           ;; V_DPM bit 3 pre-set at boot
    }
  }
}

import plugin safe "./plugins/analytics.lln" as Analytics {
  contract {
    intent "Analytics — standard bridged plugin, demand-loaded"
    access {
      grant database.read
    }
  }
}

// Both plugins callable in flows — Pay is hot, Analytics is transient
secure flow processOrder(amount: Int) -> Result<Bool, Error>
contract {
  intent "Process an order using assimilated payment gateway"
  effects { allow network.outbound, allow audit.write }
  invariant {
    ensure amount > 0
  }
}
{
  trap amount <= 0 : ERR_INVALID_AMOUNT  ;; validated — safe to proceed
  return Ok(true)
}
