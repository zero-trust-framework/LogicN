// EXPECT: ACCEPT
// R6 corpus 01 — pure flow, gauss sum (simplest Stage A == Stage B parity gate)
// Exercises: pure qualifier, Int arithmetic, return

pure flow gaussSum(n: Int) -> Int
contract {
  intent { "Compute the sum of integers 1..n using the closed-form Gauss formula." }
}
{
  return n * (n + 1) / 2
}
