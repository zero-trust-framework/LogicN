// EXPECT: ACCEPT
// R6 corpus 05 — flow with full contract: intent, effects, invariant, resilience, guard
// Exercises: secure qualifier, effects { database.write audit.write }, invariant {}, resilience {}

secure flow submitTransaction(userId: Int, amount: Int) -> Result<String, String>
contract {
  intent { "Submit a governed financial transaction. Validates inputs, writes to database, emits audit trail." }
  effects {
    database.write
    audit.write
  }
  invariant {
    ensure userId > 0
    ensure amount > 0
  }
  resilience {
    retry_on_failure 3
    timeout 5s
  }
  audit { require runtime report require actor }
}
{
  trap userId <= 0 : "FUNGI-INV-000"
  trap amount <= 0 : "FUNGI-INV-000"

  // Zero-trust: each boundary input passes an explicit validate.* gate before the governed sink
  // (discharges FUNGI-VALUESTATE-008 — unmarked boundary params reaching a sink ungated).
  let safeUser: Int = validate.userId(userId)
  let safeAmount: Int = validate.txAmount(amount)
  AuditLog.write("tx submitted: user=" + safeUser.toStr() + " amount=" + safeAmount.toStr())
  return Ok("tx:accepted")
}
