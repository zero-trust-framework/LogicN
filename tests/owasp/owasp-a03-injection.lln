// OWASP A03 — Injection
// EXPECT: ACCEPT
//
// This file DOCUMENTS the injection attack patterns LogicN prevents at compile time.
// SQL injection, command injection, and XSS are all taint-tracked at the type level.
// Tainted input (source_from: network) CANNOT reach database, shell, or HTML sinks
// without passing through a validate.* guard — that demotion is enforced by
// LLN-VALUESTATE-004.
//
// Reference: docs/Knowledge-Bases/logicn-governance-rules.md
// Rules: S-003, LLN-VALUESTATE-004 (taint demotion guard)

// ── Types ─────────────────────────────────────────────────────────────────────

type QueryResult = Result<String, InjectionError>
type InjectionError = enum { EmptyInput ValidationFailed DatabaseError CommandError }
type SafeHtml = Brand<String, "SafeHtml">
type SqlParam = Brand<String, "SqlParam">
type CmdArg = Brand<String, "CmdArg">

// ─────────────────────────────────────────────────────────────────────────────
// CASE 1: SQL Injection
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-VALUESTATE-004):
//
//   secure flow lookupUserUnsafe(readonly request: Request) -> QueryResult
//   contract {
//     intent "Look up user by raw query param"
//     effects { database.read }
//     request { body { username: unsafe String } }
//   }
//   {
//     let raw: unsafe String = request.body.username
//     // raw is network-tainted — passing it directly to a DB call
//     let row = Database.queryWhere("username = " + raw)  // ← LLN-VALUESTATE-004
//     return Ok(row)
//   }
//
// Why it is blocked: the value-state taint tracker rejects paths where a value
// typed `unsafe String` (taint tag: source_from:network) reaches a database.*
// capability sink without an intervening validate.* call that demotes the type.
// The unsafe→protected→validated pipeline is the only path through.
//
// CORRECT pattern: validate the tainted input first; the validated brand type
// (SqlParam) is permitted to reach the database sink.

;; CORRECT: SQL injection prevented by mandatory taint demotion
secure flow lookupUserSafe(readonly request: Request) -> QueryResult
contract {
  intent "Look up a user by validated username — taint-demoted before DB query"
  effects { database.read, audit.write }
  request {
    body { username: unsafe String }
  }
  audit { require runtime report }
}
{
  unsafe let rawUsername: String = request.body.username
  // validate.string demotes unsafe String → String (safe, no injection characters)
  // In a full system, validate.sqlParam would return SqlParam brand type.
  let safeUsername: String = validate.string(rawUsername)?
  trap safeUsername == "" : ERR_EMPTY_INPUT
  let row = Database.queryWhere("username = ?", safeUsername)
  AuditLog.write("UserLookup")
  return Ok(row)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 2: Command Injection
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-VALUESTATE-004):
//
//   secure flow runToolUnsafe(readonly request: Request) -> QueryResult
//   contract {
//     intent "Run a tool with caller-supplied argument"
//     effects { shell.execute }
//     request { body { toolArg: unsafe String } }
//   }
//   {
//     let arg: unsafe String = request.body.toolArg
//     shell.execute("mytool " + arg)   // ← LLN-VALUESTATE-004: tainted → shell sink
//     return Ok("done")
//   }
//
// Why it is blocked: shell.execute is a high-risk sink. The taint tracker enforces
// that any value reaching shell.* must have been validated and demoted from
// `unsafe String`. Un-validated concatenation of network input into a shell
// command is rejected at compile time.
//
// CORRECT pattern: validate the argument, check it is in the allow-list, then
// pass the clean brand type to the shell.

;; CORRECT: command argument validated and type-demoted before shell use
secure flow runToolSafe(readonly request: Request) -> QueryResult
contract {
  intent "Run an allow-listed tool — argument validated before shell execution"
  effects { shell.execute, audit.write }
  request {
    body { toolArg: unsafe String }
  }
  audit { require runtime report }
}
{
  unsafe let rawArg: String = request.body.toolArg
  let safeArg: String = validate.allowList(rawArg, ["report", "stats", "health"])?
  trap safeArg == "" : ERR_EMPTY_INPUT
  let output = shell.execute("mytool", safeArg)
  AuditLog.write("ToolExecuted: " + safeArg)
  return Ok(output)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 3: XSS — Tainted HTML input without redaction
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-VALUESTATE-004):
//
//   secure flow renderCommentUnsafe(readonly request: Request) -> QueryResult
//   contract {
//     intent "Render user comment into HTML"
//     effects { network.outbound }
//     request { body { comment: unsafe String } }
//   }
//   {
//     let raw: unsafe String = request.body.comment
//     // Reflecting raw network input into HTML output — classic reflected XSS
//     let page = "<div>" + raw + "</div>"   // ← LLN-VALUESTATE-004
//     return Ok(page)
//   }
//
// Why it is blocked: the value-state tracker rejects raw `unsafe String` values
// flowing into network-outbound response bodies without html.escape() or
// equivalent sanitization. The taint tag propagates through string concatenation.
//
// CORRECT pattern: sanitize/escape HTML before including in the response body.

;; CORRECT: XSS prevented by HTML escaping the network-tainted input
secure flow renderCommentSafe(readonly request: Request) -> QueryResult
contract {
  intent "Render a sanitized user comment — HTML-escaped before output"
  effects { network.outbound, audit.write }
  request {
    body { comment: unsafe String }
  }
  audit { require runtime report }
}
{
  unsafe let rawComment: String = request.body.comment
  let validatedComment: String = validate.string(rawComment)?
  trap validatedComment == "" : ERR_EMPTY_INPUT
  // html.escape demotes to SafeHtml brand — safe for inclusion in HTML response
  let escaped: SafeHtml = html.escape(validatedComment)
  let page = "<div>" + escaped + "</div>"
  AuditLog.write("CommentRendered")
  return Ok(page)
}
