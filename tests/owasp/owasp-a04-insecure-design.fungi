// OWASP A04 — Insecure Design
// EXPECT: ACCEPT
//
// This file DOCUMENTS the insecure design patterns Galerina prevents through its
// contract model. "Design-time" failures — missing intent, missing audit trail,
// undocumented high-risk mutations — are caught at compile time, not at runtime.
//
// Reference: docs/Knowledge-Bases/galerina-governance-rules.md
// Rules: FUNGI-GOV-010 (missing intent on governed flows), A-001 (audit.write
//        required alongside database mutations in high-trust flows)

// ── Types ─────────────────────────────────────────────────────────────────────

type DesignResult = Result<Bool, DesignError>
type DesignError = enum { EmptyInput MissingAudit Unauthorized }

// ─────────────────────────────────────────────────────────────────────────────
// CASE 1: Missing intent block on governed flows
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers FUNGI-GOV-010):
//
//   secure flow deleteRecord(id: String) -> Bool
//   contract {
//     effects { database.write, audit.write }
//     // no intent {} block ← FUNGI-GOV-010: missing intent on secure/governed flow
//   }
//   {
//     Database.delete(id)
//     return true
//   }
//
// Why it is blocked: FUNGI-GOV-010 requires every `secure` or `governed` flow to
// carry an `intent {}` block. Intent is the machine-readable governance narrative
// recorded in the .lmanifest. Without it the admission gate rejects the flow.
// (Task #4 fixed 12 flows that were missing intent; the rule is enforced in CI.)
//
// CORRECT pattern: all secure and governed flows must have `intent {}`.

;; CORRECT: intent is declared — governance verifier passes FUNGI-GOV-010
secure flow deleteRecord(id: String) -> DesignResult
contract {
  intent "Delete a record by ID — high-risk mutation, audit trail required"
  effects { database.write, audit.write }
  audit { require runtime report require actor }
}
{
  trap id == "" : ERR_EMPTY_ID
  Database.delete(id)
  AuditLog.write("RecordDeleted: " + id)
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 2: Database mutation without an audit trail
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — advisory FUNGI-GOV-011 / A-001 pattern violation):
//
//   secure flow updateBalanceSilent(accountId: String, amount: Int) -> Bool
//   contract {
//     intent "Update account balance without audit"
//     effects { database.write }   // ← missing audit.write alongside mutation
//     // audit {} block omitted entirely
//   }
//   {
//     Ledger.updateBalance(accountId, amount)
//     // No AuditLog.write — mutation is invisible to governance tooling
//     return true
//   }
//
// Why it is blocked: rule A-001 states that high-trust mutations (database.write)
// should declare audit.write in effects and include AuditLog.write in the body.
// The governance verifier emits an advisory (FUNGI-GOV-011) when database.write
// appears in effects without a corresponding audit.write. High-risk flows with
// `audit { require runtime report }` enforce this at compile time.
//
// CORRECT pattern: declare audit.write alongside every database mutation and
// include AuditLog.write in the body.

;; CORRECT: mutation accompanied by mandatory audit trail
secure flow updateBalance(accountId: String, amount: Int) -> DesignResult
contract {
  intent "Update account balance — every mutation must be auditable by design"
  effects { database.write, audit.write }
  audit { require runtime report require actor require cryptographic_state_hash }
  limits { memory 32mb request_time 500ms }
  invariant {
    ensure amount > 0
  }
}
{
  trap accountId == "" : ERR_EMPTY_ACCOUNT
  trap amount <= 0 : ERR_NON_POSITIVE_AMOUNT
  Ledger.updateBalance(accountId, amount)
  AuditLog.write("BalanceUpdated: " + accountId)
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 3: Sensitive flow with no resource limits
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — advisory FUNGI-GOV-012):
//
//   secure flow processBulkImport(data: String) -> Bool
//   contract {
//     intent "Import bulk data"
//     effects { database.write, audit.write }
//     // no limits {} block ← no resource ceiling declared
//   }
//   { ... }
//
// Why it matters: insecure design includes missing resource controls (DoS by design).
// Galerina's architecture patterns (Pattern 3, high-trust mutation) mandate `limits {}`
// on flows that write to databases to prevent unbounded memory/time consumption.
//
// CORRECT pattern: declare limits alongside every database-writing flow.

;; CORRECT: limits block prevents resource exhaustion by design
secure flow processBulkImport(data: String) -> DesignResult
contract {
  intent "Import bulk data within explicit resource limits — no unbounded execution"
  effects { database.write, audit.write }
  audit { require runtime report }
  limits { memory 64mb request_time 10s }
}
{
  trap data == "" : ERR_EMPTY_DATA
  let rows = Csv.parse(data)
  Database.bulkInsert(rows)
  AuditLog.write("BulkImportCompleted")
  return Ok(true)
}
