// OWASP A01 — Broken Access Control
// EXPECT: ACCEPT
//
// This file DOCUMENTS the access control violations LogicN prevents at compile time.
// Each "bad pattern" section is shown as a comment with the LLN code it would trigger.
// The CORRECT pattern follows each bad pattern as live compilable code.
//
// Reference: docs/Knowledge-Bases/logicn-governance-rules.md
// Rules: E-001 (declared effects), C-001 (no wildcard caps), LLN-GOV-004, LLN-INHERIT-002

// ── Types ─────────────────────────────────────────────────────────────────────

type AccessResult = Result<Bool, AccessError>
type AccessError = enum { Denied Unauthorized BadInput }

// ─────────────────────────────────────────────────────────────────────────────
// CASE 1: Undeclared effect
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-EFFECT-001):
//
//   secure flow writeWithoutDeclaringEffect(data: String) -> Bool
//   contract {
//     intent "Attempt to write without declaring the effect"
//     effects {}   // empty — but body calls Database.insert
//   }
//   {
//     Database.insert(data)   // ← LLN-EFFECT-001: database.write undeclared
//     return true
//   }
//
// Why it is blocked: LogicN is deny-by-default on all effects. If the effects {}
// block is empty, any capability call in the body is undeclared and the governance
// verifier raises LLN-EFFECT-001. There is no "just works" escape hatch.
//
// CORRECT pattern: every effect the body uses must appear in effects {}.

;; CORRECT: write effect declared explicitly
secure flow writeWithDeclaredEffect(data: String) -> AccessResult
contract {
  intent "Write data to the database with an explicitly declared effect"
  effects { database.write, audit.write }
  audit { require runtime report }
}
{
  trap data == "" : ERR_EMPTY_DATA
  Database.insert(data)
  AuditLog.write("DataWritten: " + data)
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 2: Wildcard capability grant
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-CAP-001):
//
//   secure flow openNetworkAccess(url: String) -> Bool
//   contract {
//     intent "Fetch from any network endpoint"
//     effects { allow network.* }   // ← LLN-CAP-001: wildcard capability
//   }
//   { ... }
//
// Why it is blocked: wildcard capability grants were removed from NetworkConstraint
// in DRCM Phase 1 (task #30). A flow must name the exact capability token
// (network.outbound, network.inbound, etc.) — globs are not accepted.
//
// CORRECT pattern: enumerate the exact capability tokens needed.

;; CORRECT: specific network capability declared, no wildcard
secure flow fetchFromEndpoint(url: String) -> AccessResult
contract {
  intent "Fetch data from a known external endpoint"
  effects { network.outbound, audit.write }
  audit { require runtime report }
}
{
  trap url == "" : ERR_EMPTY_URL
  let response = http.get(url)
  AuditLog.write("FetchAttempt: " + url)
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 3: Domain guard violation — effects exceed guard ceiling
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-GOV-004):
//
//   guard ReadOnlyServiceGuard {
//     permitted_effects { database.read }
//   }
//
//   secure flow writeInReadOnlyService(data: String) -> Bool
//   contract [conforms_to: ReadOnlyServiceGuard] {
//     intent "Violate the guard ceiling by writing"
//     effects { database.write }   // ← LLN-GOV-004: exceeds guard ceiling
//   }
//   { ... }
//
// Why it is blocked: guard-domain-ceiling enforcement (task #56, LLN-GOV-004)
// ensures effects {} ⊆ guard.permitted_effects. A flow may never claim more
// capability than its guard ceiling allows.
//
// CORRECT pattern: effects must be a subset of the guard's permitted_effects.

guard ReadOnlyServiceGuard {
  permitted_effects {
    database.read
    audit.write
  }
}

;; CORRECT: effects are a strict subset of the guard ceiling
secure flow readWithinGuard(query: String) -> AccessResult
contract [conforms_to: ReadOnlyServiceGuard] {
  intent "Read data — effects stay within the ReadOnly guard ceiling"
  effects { database.read, audit.write }
  audit { require runtime report }
}
{
  trap query == "" : ERR_EMPTY_QUERY
  let result = Database.query(query)
  AuditLog.write("QueryExecuted")
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 4: Policy privilege escalation — child guard exceeds parent
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-INHERIT-002):
//
//   guard ParentPolicy {
//     permitted_effects { database.read, audit.write }
//   }
//   guard EscalatingChildPolicy {
//     parent_policy: ParentPolicy
//     permitted_effects { network.outbound }   // ← LLN-INHERIT-002: not a subset
//   }
//
// Why it is blocked: the hierarchical policy inheritance verifier (task #72)
// checks that child.permitted_effects ⊆ parent.permitted_effects. A child guard
// that adds capabilities the parent does not allow is a privilege escalation and
// is rejected at compile time with LLN-INHERIT-002.
// See tests/syntax/policy-hierarchy-bad.lln for the isolated negative case.
//
// CORRECT pattern: child guard is always a strict subset of the parent.

guard FinanceParentGuard {
  permitted_effects {
    database.write
    database.read
    audit.write
  }
  enforced_limits {
    max_memory_ceiling: 16MB
  }
}

guard InvoiceReadChildGuard {
  parent_policy: FinanceParentGuard
  permitted_effects {
    database.read
    audit.write
  }
  enforced_limits {
    max_memory_ceiling: 8MB
  }
}

;; CORRECT: conforms to the narrower child guard — no escalation
secure flow getInvoiceTotal(invoiceId: String) -> AccessResult
contract [conforms_to: InvoiceReadChildGuard] {
  intent "Read invoice total — read-only, strictly within child guard ceiling"
  effects { database.read, audit.write }
  audit { require runtime report }
}
{
  trap invoiceId == "" : ERR_EMPTY_INVOICE_ID
  let total = InvoicesDB.getTotalFor(invoiceId)
  AuditLog.write("InvoiceRead: " + invoiceId)
  return Ok(true)
}
