// OWASP A09 — Security Logging and Monitoring Failures
// EXPECT: ACCEPT
//
// This file DOCUMENTS the logging and monitoring failures LogicN prevents.
// High-risk flows are required to have audit.write in effects. Audit events
// are structured (CBOR Tag 410 AuditEvent schema, task #75), not printf strings.
// govComment (;;) annotations are preserved in the .lmanifest narrative.
//
// Reference: docs/Knowledge-Bases/logicn-governance-rules.md
// Rules: A-001 (audit.write on high-risk flows), AU rule category,
//        LLN-AUDIT-001 (structured AuditEvent format), govComment (task #93)

// ── Types ─────────────────────────────────────────────────────────────────────

type LogResult = Result<Bool, LogError>
type LogError = enum { EmptyInput LogFailure AuditError }
type PatientId = Brand<String, "PatientId">

// ─────────────────────────────────────────────────────────────────────────────
// CASE 1: High-risk mutation without audit.write
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — advisory LLN-GOV-011 / A-001):
//
//   secure flow deleteMedicalRecord(patientId: String) -> Bool
//   contract {
//     intent "Delete a medical record"
//     effects { database.write }   // ← audit.write missing
//     // No audit {} block — forensic trail absent
//   }
//   {
//     MedicalDB.delete(patientId)
//     return true
//   }
//
// Why it matters: database.write without audit.write leaves mutations invisible.
// The governance verifier emits LLN-GOV-011 advisory when database.write appears
// in effects without a corresponding audit.write. For `audit { require runtime report }`
// flows the check is hard — compilation fails unless audit.write is present.
//
// CORRECT pattern: every database mutation must declare audit.write and call AuditLog.write.

;; CORRECT: deletion accompanied by mandatory structured audit event
secure flow deleteMedicalRecord(patientId: PatientId) -> LogResult
contract {
  intent "Delete a medical record — every deletion must produce a forensic audit event"
  effects { database.write, audit.write }
  privacy {
    phi patientId masked_in_audit
    require redaction before audit.write
  }
  audit { require runtime report require actor require cryptographic_state_hash }
}
{
  trap patientId == "" : ERR_EMPTY_PATIENT_ID
  let redactedId: redacted String = redact(patientId)
  MedicalDB.delete(patientId)
  ;; govComment — this deletion event is preserved in .lmanifest narrative
  AuditLog.write({
    event: "MedicalRecordDeleted",
    patient_ref: redactedId
  })
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 2: Audit events must be structured (AuditEvent schema, not printf)
// ─────────────────────────────────────────────────────────────────────────────
//
// BAD PATTERN (do not use — triggers LLN-AUDIT-001):
//
//   secure flow logPaymentBad(txId: String, amount: Int) -> Bool
//   contract {
//     intent "Log payment as unstructured string"
//     effects { audit.write }
//   }
//   {
//     // Free-text printf-style logging is not an AuditEvent (CBOR Tag 410).
//     // It cannot be machine-verified, filtered, or included in the epilogue receipt.
//     AuditLog.write("Payment: " + txId + " amount=" + amount)  // ← LLN-AUDIT-001
//     return true
//   }
//
// Why it is blocked: task #75 introduced the structured AuditEvent schema
// (CBOR Tag 410). Audit events must be structured records (field: value pairs)
// so they can be serialized to CBOR, hashed into the epilogue receipt, and
// queried by the governance tooling. Free-text concatenation is flagged by
// LLN-AUDIT-001 (advisory in Stage A, enforced in Stage B).
//
// The pattern AuditLog.write("string: " + value) IS accepted in Stage A for
// simple informational logs. For high-trust flows, the structured record form
// is the canonical pattern.
//
// CORRECT pattern: use a structured record for AuditLog.write on high-trust flows.

;; CORRECT: structured AuditEvent record — machine-parseable, receipt-hashable
secure flow logPayment(txId: String, amount: Int) -> LogResult
contract {
  intent "Record a payment event as a structured audit entry — CBOR Tag 410 compatible"
  effects { database.write, audit.write }
  audit { require runtime report require cryptographic_state_hash }
  limits { memory 16mb request_time 500ms }
}
{
  trap txId == "" : ERR_EMPTY_TX_ID
  trap amount <= 0 : ERR_NON_POSITIVE_AMOUNT
  Database.insertPayment(txId, amount)
  ;; govComment — structured audit event: every field is typed and indexed
  AuditLog.write({
    event: "PaymentCompleted",
    transaction_id: txId,
    amount: amount
  })
  return Ok(true)
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE 3: govComment annotations preserved in .lmanifest narrative
// ─────────────────────────────────────────────────────────────────────────────
//
// govComment (;;) lines are collected by the compiler (task #93) and stored in
// the .lmanifest under narrative[]. They create a machine-readable governance
// story that auditors can inspect without re-reading source code.
//
// BAD PATTERN (do not use):
//   Using ordinary // comments for governance intent — they are stripped at
//   parse time and do not appear in the .lmanifest. Auditors cannot see them.
//
// CORRECT pattern: use ;; govComment syntax for any remark that should survive
// into the manifest narrative.

;; govComment — OWASP A09 compliance: every access to clinical data is traced
;; govComment — audit event schema: CBOR Tag 410, fields: event, patient_ref, actor
secure flow accessClinicalRecord(patientId: PatientId) -> LogResult
contract {
  intent "Access a clinical record — access event always logged with patient ref and actor"
  effects { database.read, audit.write }
  privacy {
    phi patientId masked_in_audit
    require redaction before audit.write
  }
  audit { require runtime report require actor }
}
{
  trap patientId == "" : ERR_EMPTY_PATIENT_ID
  let record = MedicalDB.find(patientId)
  let redactedId: redacted String = redact(patientId)
  ;; govComment — access logged to append-only audit chain (epilogue receipt)
  AuditLog.write({
    event: "ClinicalRecordAccessed",
    patient_ref: redactedId
  })
  return Ok(true)
}
