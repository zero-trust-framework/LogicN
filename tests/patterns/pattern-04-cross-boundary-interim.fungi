// EXPECT: ACCEPT
// Pattern 4 — Cross-Boundary Workflow, Interim BoundaryProxy (drcm_stable_v0)
// Reference: docs/Knowledge-Bases/galerina-architecture-patterns.md
//            packages-galerina/galerina-core-security/src/interim.fungi
//
// Use when: a flow calls external services, third-party APIs, or code in a different trust context.
// BEFORE DRCM Phase 5: route cross-boundary calls through security::interim::BoundaryProxy.
// AFTER DRCM Phase 5: replace the proxy block with `step external_api::call(payload)`.
// Rules: S-001, S-006 (interim), I-001 (planned)

type OrderPayload = record { order_id: String, items: Int }
type ShipmentConfirmation = record { tracking_id: String, carrier: String }
type LogisticsError = enum { NetworkTimeout InvalidPayload ServiceUnavailable }

// Internal pure helper — same isolate, no boundary crossing needed
pure flow sanitizeOrderId(raw: String) -> String
contract {
  intent { "Strip whitespace and invalid characters from a raw order identifier." }
}
{
  return String.trim(raw)
}

// Cross-boundary flow — uses interim BoundaryProxy until DRCM Phase 5 ships
secure flow fulfillShipment(readonly payload: OrderPayload) -> Result<ShipmentConfirmation, LogisticsError>
contract {
  intent { "Trigger fulfillment of a confirmed order via the logistics network." }
  effects { network.outbound, database.write, audit.write }
  limits { memory 32mb request_time 5s }
}
{
  // Pure internal logic — same isolate
  let safeId: String = sanitizeOrderId(payload.order_id)

  // --- INTERIM BOUNDARYPOXY PATTERN ---
  // Cross-boundary call: route through the interim validation proxy.
  // Positional arguments (Stage A does not support named args at call sites — see S-007).
  // Position 0: caller module, Position 1: target, Position 2: payload_size_bytes
  let receipt = security::interim::pre_flight_check(
    "fulfillShipment",
    "logistics_api::createShipment",
    String.length(safeId)
  )

  if !receipt.is_approved {
    return Err(LogisticsError.NetworkTimeout)
  }

  // Synchronous call in current runtime (future: step logistics_api::createShipment(safeId))
  let trackingId: String = logistics_api::createShipment(safeId)
  let carrier: String    = logistics_api::confirmDispatch(trackingId)

  security::interim::post_flight_cleanup(receipt)

  Database.updateOrderStatus(payload.order_id, "shipped")
  AuditLog.write("ShipmentDispatched: " + trackingId)

  return Ok(ShipmentConfirmation { tracking_id: trackingId, carrier: carrier })

  // DRCM Phase 5 — replace the BoundaryProxy block above with:
  // @experimental_profile(name: "drcm_core_v1", status: "planned_phase_5") {
  //   let tracking      = step logistics_api::createShipment(safeId)
  //   let confirmation  = step logistics_api::confirmDispatch(tracking.tracking_id)
  // }
}
