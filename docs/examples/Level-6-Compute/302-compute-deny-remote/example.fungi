/// example: 302-compute-deny-remote
/// level: 6
/// concept: denying remote execution in a secure credit-scoring flow
/// expected_diagnostics: none
/// ai_rule: Use deny [remote.execution] for data that must not leave the device.
/// test_status: stable

secure flow scoreCredit(readonly request: Request) -> ScoreCreditResult

contract {
  // Result alias — deny [remote.execution] keeps inference on-device
  types {
    type ScoreCreditResult = Result<Response, ApiError>
  }

  intent {
    "Score credit risk without remote execution"
  }

  effects {
    ai.inference
    audit.write
  }
}
{
  compute target best { prefer [npu, gpu, cpu] deny [remote.execution] fallback cpu }

  unsafe let rawScore: String = request.body.rawScore
  let score: protected CreditScore = validate.creditScore(rawScore)?
  let features: Tensor<Float32, [1, 64]> = CreditFeatures.from(score)?
  let result = CreditModel.run(features)?
  AuditLog.write({ event: "CreditScored", scoreId: redact(score) })
  return Ok(Response.ok(result))
}
