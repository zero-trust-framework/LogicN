/// example: 310-compute-fallback-required
/// level: 6
/// concept: mandatory fallback declaration when targeting npu or gpu
/// expected_diagnostics: none
/// ai_rule: Always declare fallback cpu when targeting npu or gpu.
/// test_status: stable

secure flow runFraudModel(tx: Transaction) -> RunFraudModelResult

contract {
  // Result alias — npu/gpu preference with mandatory cpu fallback
  types {
    type RunFraudModelResult = Result<FraudScore, AiError>
  }

  intent {
    "Run fraud model inference on NPU or GPU with mandatory CPU fallback and audit trail."
  }

  effects {
    ai.inference
    audit.write
  }
}
{
  compute target best { prefer [npu, gpu] fallback cpu }

  let features: Tensor<Float32, [1, 32]> = FraudFeatures.from(tx)?
  let score: FraudScore = FraudModel.run(features)?
  // Zero-trust: gate the boundary input through an explicit validate.* gate before the
  // governed audit sink (discharges FUNGI-VALUESTATE-008 — an unmarked boundary param
  // reaching a sink ungated).
  let safeTxId: protected String = validate.id(tx.id)?
  AuditLog.write({ event: "FraudModelRun", txId: redact(safeTxId) })
  return Ok(score)
}
