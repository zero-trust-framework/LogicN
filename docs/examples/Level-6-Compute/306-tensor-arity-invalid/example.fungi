/// example: 306-tensor-arity-invalid
/// test_status: stable
/// level: 6
/// concept: Tensor requires exactly two type parameters: element type and shape
/// expected_diagnostics: FUNGI-TYPE-009
/// ai_rule: Tensor<T, Shape> requires both an element type and a shape argument; omitting either is a type error.

// This is invalid — Tensor requires both an element type AND a shape.
pure flow example() -> Void {
  let x: Tensor<Float32> = None
}
