/// example: 075-money-divide-decimal
/// level: 2
/// concept: Money<GBP> divided by Decimal
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Money<GBP> / Decimal is valid and yields Money<GBP>.

pure flow example(total: Money<GBP>) -> Money<GBP> {
  let share: Money<GBP> = total / Decimal("4")
  return share
}
