/// example: 060-invalid-email-assignment
/// test_status: stable
/// level: 2
/// concept: direct assignment to protected Email is forbidden
/// expected_diagnostics: FUNGI-TYPE-003
/// ai_rule: You cannot assign an unvalidated String to a protected type. Use validate.email(...).

type Email = Brand<String, EmailTag>

pure flow example(rawEmail: String) -> Void {
  let email: protected Email = rawEmail
}
