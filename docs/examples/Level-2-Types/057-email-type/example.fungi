/// example: 057-email-type
/// level: 2
/// concept: protected Email domain type
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Email values come from validate.email().

type Email = Brand<String, EmailTag>

pure flow example(rawEmail: String) -> protected Email {
  let email: protected Email = validate.email(rawEmail)?
  return email
}
