/// example: 082-readonly-view
/// level: 2
/// concept: ReadOnlyView<T> generic type
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: ReadOnlyView<T> exposes a collection without mutation methods.

pure flow example(source: List<User>) -> ReadOnlyView<User> contract {
  intent { "Expose a collection of users without mutation methods." }
} {
  let users: ReadOnlyView<User> = source.slice(0, source.length)
  return users
}
