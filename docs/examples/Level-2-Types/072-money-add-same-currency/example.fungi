/// example: 072-money-add-same-currency
/// level: 2
/// concept: Money<GBP> addition with same currency
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Money<GBP> + Money<GBP> is valid and yields Money<GBP>.

pure flow example(subtotal: Money<GBP>, vat: Money<GBP>) -> Money<GBP> {
  let total: Money<GBP> = subtotal + vat
  return total
}
