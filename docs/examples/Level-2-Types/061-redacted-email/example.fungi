/// example: 061-redacted-email
/// level: 2
/// concept: redacted Email label
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Use redact() to convert a protected value to a redacted value for audit logging.

type Email = Brand<String, EmailTag>

pure flow example(email: protected Email) -> Void {
  let auditEmail: redacted Email = redact(email)
}
