/// example: 169-secret-comparison
/// level: 4
/// concept: direct equality comparison on secrets is forbidden
/// expected_diagnostics: LLN-SECRET-002
/// ai_rule: Never compare secrets with ==. Use constantTimeEquals(...) to prevent timing attacks.
/// test_status: stable

pure flow example(apiKey: SecureString, suppliedKey: SecureString) -> Bool {
  return apiKey == suppliedKey
}
