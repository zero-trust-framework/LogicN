/// example: 154-validate-email
/// level: 4
/// concept: validating unsafe email to protected Email
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Email values come from validate.email(). The ? propagates validation failure.

secure flow createUser(request: Request) -> CreateUserResult

contract {
  // Security intent: raw email from the request boundary must pass validate.email()
  // before it can be stored. validate.email() elevates the value to protected Email.
  types {
    type CreateUserResult = Result<UserId, UserError>
  }

  intent {
    "Validate an unsafe email from the request boundary and create a user record."
  }

  request {
    body {
      email: unsafe String
      // Parser note: body sub-block parsed generically, enforcement pending
    }
  }

  effects {
    database.write
    audit.write
  }
}
{
  unsafe let rawEmail: String = request.body.email
  let email: protected Email = validate.email(rawEmail)?
  let id = UsersDB.insert({ email: email })?
  AuditLog.write({ action: "createUser", id: id })
  return Ok(id)
}
