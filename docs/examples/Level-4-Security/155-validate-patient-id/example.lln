/// example: 155-validate-patient-id
/// level: 4
/// concept: validating unsafe patientId to protected PatientId
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: PatientId values come from validate.patientId().

secure flow createPatient(request: Request) -> CreatePatientResult

contract {
  // Security intent: raw patient ID from the HTTP boundary must be validated
  // via validate.patientId() before any database write or audit operation.
  types {
    type CreatePatientResult = Result<PatientId, PatientError>
  }

  intent {
    "Validate an unsafe patient ID from the request boundary and create a patient record."
  }

  request {
    body {
      patientId: unsafe String
      // Parser note: body sub-block parsed generically, enforcement pending
    }
  }

  effects {
    database.write
    audit.write
  }
}
{
  unsafe let rawPatientId: String = request.body.patientId
  let patientId: protected PatientId = validate.patientId(rawPatientId)?
  let id = PatientsDB.insert({ patientId: patientId })?
  AuditLog.write({ action: "createPatient", id: id })
  return Ok(id)
}
