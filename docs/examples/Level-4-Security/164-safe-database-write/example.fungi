/// example: 164-safe-database-write
/// level: 4
/// concept: protected value is safe to write to database
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Validated protected values can be stored in a database sink with database.write declared.

secure flow savePatient(request: Request) -> SavePatientResult

contract {
  // Security intent: only validated (protected) values may be written to the database.
  // Unsafe raw values from the request boundary must pass validate.email() first.
  types {
    type SavePatientResult = Result<PatientId, PatientError>
  }

  intent {
    "Validate raw email from the request boundary and persist the patient record safely."
  }

  effects {
    database.write
    audit.write
  }
}
{
  unsafe let rawEmail: String = request.body.email
  let email: protected Email = validate.email(rawEmail)?
  let id = PatientsDB.insert({ email: email })?
  let auditEmail: redacted Email = redact(email)
  AuditLog.write({ action: "savePatient", email: auditEmail, patientId: id })
  return Ok(id)
}
