/// example: 173-validation-chain
/// level: 4
/// concept: complete canonical trust flow chain
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: This is the canonical Galerina trust flow: unsafe -> validate -> protected -> redact -> audit.

secure flow processUserEmail(request: Request) -> ProcessUserEmailResult

contract {
  // Security intent: canonical trust chain — raw boundary input is unsafe, validation
  // gates it to protected, redact() prepares it for the audit sink.
  // No unvalidated or unredacted PII may reach any governed sink.
  types {
    type ProcessUserEmailResult = Result<Unit, UserError>
  }

  intent {
    "Demonstrate the canonical unsafe -> validate -> protected -> redact -> audit trust chain."
  }

  effects {
    database.write
    audit.write
  }
}
{
  unsafe let rawEmail: String = request.body.email

  let email: protected Email = validate.email(rawEmail)?

  let auditEmail: redacted Email = redact(email)

  AuditLog.write({ action: "processUserEmail", email: auditEmail })

  return Ok(unit)
}
