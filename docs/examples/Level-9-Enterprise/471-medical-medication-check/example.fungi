/// example: 471-medical-medication-check
/// level: 9
/// concept: medical domain — record types Patient and Medication, interaction validation pattern
/// expected_diagnostics: none
/// ai_rule: Medical flows must use protected types for all PII (PatientId, MedicationCode), declare pii.read and audit.write effects, and redact protected values in audit entries.
/// test_status: stable

event MedicationCheckPerformed

record Patient {
  patientId: String
  patientName: String
  nhsNumber: String
}

record Medication {
  medicationCode: String
  medicationName: String
  doseUnit: String
}

record InteractionCheckRequest {
  requestPatientId: String
  requestMedA: String
  requestMedB: String
}

record InteractionCheckResponse {
  hasInteraction: Bool
  interactionSeverity: String
  clinicalAdvice: String
}

secure flow checkMedicationInteraction(
  readonly request: Request
) -> MedicationCheckResult

contract {
  // Result alias — PII and PHI for two medication codes; all redacted in audit
  types {
    type MedicationCheckResult = Result<Response, MedicalError>
  }

  intent {
    "Check whether two medications have a known interaction for a given patient. Returns severity and clinical advice."
  }

  request {
    accepts InteractionCheckRequest
    params {
      requestPatientId: unsafe String
      requestMedA: unsafe String
      requestMedB: unsafe String
    }
    requires {
      actor
      trace_id
    }
  }

  response {
    returns InteractionCheckResponse
    exposes {
      hasInteraction
      interactionSeverity
      clinicalAdvice
    }
    denies {
      nhsNumber
      fullName
      internalCode
    }
  }

  context {
    require actor
    require trace_id
  }

  effects {
    pii.read
    database.read
    audit.write
  }

  privacy {
    contains PII
    contains PHI
    retention 10 years
    deny protected NhsNumber to response
    deny protected values in logs
    require redaction before audit.write
  }

  errors {
    returns {
      MedicalError.NotFound
      MedicalError.Unauthorised
      MedicalError.Internal
    }
    map PatientNotFound to MedicalError.NotFound
    map AccessDenied to MedicalError.Unauthorised
    expose {
      MedicalError.NotFound
      MedicalError.Unauthorised
    }
    redact {
      MedicalError.Internal
    }
    audit {
      MedicalError.Internal
      MedicalError.Unauthorised
    }
  }

  rules {
    require actor before database.read
    require clinical_role on actor
    require trace_id before audit.write
    deny protected NhsNumber to response
    require redaction before audit.write
  }

  observability {
    trace flow
    measure latency
    deny protected values in logs
    require trace_id
  }

  events {
    emits MedicationCheckPerformed
  }

  audit {
    require proof
    require runtime report
    require signed attestation
  }
}

{
  let actor = context.actor
  let traceId = context.trace_id

  unsafe let rawPatientId: String = request.params.requestPatientId
  unsafe let rawMedA: String = request.params.requestMedA
  unsafe let rawMedB: String = request.params.requestMedB

  let patientId: protected PatientId = validate.patientId(rawPatientId)?
  let medCodeA: protected MedicationCode = validate.medicationCode(rawMedA)?
  let medCodeB: protected MedicationCode = validate.medicationCode(rawMedB)?

  let patient: Patient = PatientDB.findById(patientId)?
  let medA: Medication = MedicationsDB.findByCode(medCodeA)?
  let medB: Medication = MedicationsDB.findByCode(medCodeB)?

  let result = InteractionDB.check({
    patientId: patientId,
    medicationA: medCodeA,
    medicationB: medCodeB
  })?

  AuditLog.write({
    event: "MedicationCheckPerformed",
    actor: actor.id,
    traceId: traceId,
    patientId: redact(patientId),
    medicationA: redact(medCodeA),
    medicationB: redact(medCodeB),
    hasInteraction: result.hasInteraction
  })

  emit MedicationCheckPerformed

  return Ok(Response.okJson({
    hasInteraction: result.hasInteraction,
    interactionSeverity: result.interactionSeverity,
    clinicalAdvice: result.clinicalAdvice
  }))
}
