/// example: 104-multiple-effects
/// level: 3
/// concept: flow declaring multiple effects
/// expected_diagnostics: none
/// ai_rule: List all required effects in the contract effects block.
/// test_status: stable

secure flow syncOrder(order: Order) -> SyncOrderResult

contract {
  types {
    type SyncOrderResult = Result<Unit, SyncError>
  }

  intent {
    "Insert a validated order into the database, sync it to an external service, and write an audit record."
  }

  effects {
    database.write
    network.outbound
    audit.write
  }
}
{
  let safeOrder: protected Order = validate.order(order)?
  let orderId = OrdersDB.insert(safeOrder)?
  let _ = http.post("https://sync.example.com/orders", safeOrder)?
  AuditLog.write({ action: "syncOrder", orderId: orderId })
  return Ok(unit)
}
