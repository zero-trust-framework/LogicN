/// example: 101-pure-no-effects
/// level: 3
/// concept: pure flow has no effects
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Pure flows cannot perform I/O or call effectful operations.

pure flow calculateVat(price: Money<GBP>) -> Money<GBP>

contract {
  intent {
    "Calculate VAT at 20% for a given price with no side effects."
  }
}
{
  return price * Decimal("0.20")
}
