/// example: 009-unsafe-let-boundary
/// level: 1
/// concept: unsafe let — boundary input
/// expected_diagnostics: none
/// ai_rule: Data from external boundaries starts as unsafe.
/// test_status: stable

secure flow readBoundary(readonly request: Request) -> String

contract {
  intent {
    "Read raw boundary input as unsafe data owned by a governed flow."
  }
}
{
  unsafe let rawBody: String =
    request.body

  return rawBody
}
