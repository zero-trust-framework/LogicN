/// example: 007-readonly-parameter
/// level: 1
/// concept: readonly parameter
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: readonly parameters cannot be reassigned inside the flow.

pure flow greet(readonly name: String) -> String

contract {
  intent {
    "Return a greeting string for the given name, without modifying the input."
  }
}
{
  return "Hello " + name
}
