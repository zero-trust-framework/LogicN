/// example: 013-match-option
/// level: 1
/// concept: match on Option
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Every match on Option must handle both Some and None.

pure flow example(user: Option<User>) -> Void {
  match user {

    Some(value) =>
      print(value.name)

    None =>
      print("Missing")

    _ =>
      print("Unknown")
  }
}
