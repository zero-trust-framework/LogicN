/// example: 012-match-result
/// level: 1
/// concept: match on Result
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Every match on Result must handle both Ok and Err.

pure flow example() -> Void {
  match parseAge("42") {

    Ok(age) =>
      print(age)

    Err(err) =>
      print(err)

    _ =>
      print("unknown")
  }
}
