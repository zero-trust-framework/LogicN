/// example: 001-pure-flow
/// level: 1
/// concept: pure flow
/// expected_diagnostics: none
/// test_status: stable
/// ai_rule: Use pure flow for deterministic logic with no effects.

pure flow calculateVat(price: Money<GBP>) -> Money<GBP>

contract {
  intent {
    "Calculate the VAT amount for a given price at the standard 20% rate."
  }
}
{
  return price * Decimal("0.20")
}
