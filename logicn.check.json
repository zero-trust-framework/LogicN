{
  "_comment": "logicn.check.json — project-level configuration for `logicn check`",
  "_docs": "docs/Knowledge-Bases/logicn-check-config.md",

  "profile": "production",

  "rules": {
    "LLN-TAINT-001": "error",
    "LLN-TAINT-003": "error",
    "LLN-TAINT-004": "warning",
    "LLN-TAINT-005": "error",
    "LLN-TAINT-006": "error",

    "LLN-PROFILE-001": "error",
    "LLN-PROFILE-002": "error",
    "LLN-PROFILE-005B": "error",
    "LLN-PROFILE-006": "warning",

    "LLN-VAL-001": "error",
    "LLN-VAL-002": "error",

    "LLN-GOV-002": "error",
    "LLN-GOV-009": "error",

    "LLN-SYNTAX-010": "error",
    "LLN-SYNTAX-LEGACY-001": "error",
    "LLN-SYNTAX-LEGACY-002": "warning",

    "LLN-STYLE-001": "off",

    "LLN-SOURCE-ESCAPE-001": "error",
    "LLN-SEC-020": "error",
    "LLN-SEC-021": "error"
  },

  "ignore": [
    "tests/**",
    "examples/**",
    "docs/**"
  ],

  "minSeverity": "warning",

  "security": false,
  "flowgraph": false,

  "_note": "Set security:true and flowgraph:true to enable @logicn/devtools-security and @logicn/devtools-flowgraph integration (adds ~2s per file). Recommended for CI but slow for local checks."
}
