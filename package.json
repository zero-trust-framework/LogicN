{
  "name": "@logicn/cli",
  "version": "0.1.0",
  "description": "LogicN compiler and runtime CLI — compile .lln programs to WASM, run them, type-check with governance.",
  "type": "module",
  "bin": {
    "logicn": "./logicn.mjs"
  },
  "scripts": {
    "test": "node scripts/run-all-tests.cjs",
    "test:core": "node scripts/run-all-tests.cjs --core",
    "test:list": "node scripts/run-all-tests.cjs --list"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["logicn", "compiler", "governance", "wasm"],
  "license": "Apache-2.0"
}
