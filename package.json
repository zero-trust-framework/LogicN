{
  "name": "@galerina/cli",
  "version": "1.0.0-beta.2",
  "description": "Galerina compiler and runtime CLI — compile .spore programs to WASM, run them, type-check with governance.",
  "type": "module",
  "bin": {
    "galerina": "./galerina.mjs",
    "spore": "./galerina.mjs"
  },
  "scripts": {
    "test": "node scripts/run-all-tests.cjs",
    "test:core": "node scripts/run-all-tests.cjs --core",
    "test:list": "node scripts/run-all-tests.cjs --list"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["galerina", "compiler", "governance", "wasm"],
  "license": "Apache-2.0"
}
