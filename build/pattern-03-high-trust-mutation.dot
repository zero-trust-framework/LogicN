digraph "pattern-03-high-trust-mutation_manifest" {
  graph [label="pattern-03-high-trust-mutation.lmanifest — PolicyResolutionDAG\nallowed=00011100 denied=00000000" fontsize=12 labelloc=t]
  node [shape=box fontname="Courier" fontsize=10]
  rankdir=LR

  cap_0 [label="network.outbound\nbit0 —" style=filled fillcolor=lightgray]
  cap_1 [label="storage.write\nbit1 —" style=filled fillcolor=lightgray]
  cap_2 [label="secret.access\nbit2 ✓" style=filled fillcolor=lightgreen]
  cap_3 [label="audit.write\nbit3 ✓" style=filled fillcolor=lightgreen]
  cap_4 [label="database.write\nbit4 ✓" style=filled fillcolor=lightgreen]
  cap_5 [label="ai.inference\nbit5 —" style=filled fillcolor=lightgray]
  cap_6 [label="shell.execute\nbit6 —" style=filled fillcolor=lightgray]
  cap_7 [label="native.call\nbit7 —" style=filled fillcolor=lightgray]

  f_transferFunds [label="transferFunds\n3 effect(s)" style=filled fillcolor=lightyellow]
  f_transferFunds -> cap_4 [color=gray]
  f_transferFunds -> cap_3 [color=gray]
  f_transferFunds -> cap_2 [color=gray]
  f_intent_declared_transferFunds [label="intent_declared:transferFunds\n0 effect(s)" style=filled fillcolor=lightblue]
  f_audit_required_transferFunds [label="audit_required:transferFunds\n0 effect(s)" style=filled fillcolor=lightblue]
  f_invariant_runtime_transferFunds_ensure_payload_amount___0_runtime_precheck [label="invariant_runtime:transferFunds:ensure payload.amount > 0:runtime-precheck\n0 effect(s)" style=filled fillcolor=lightblue]

  dag_valid [label="dag_edge_valid\nbit 8\n(Topology FIRST)" style=filled fillcolor=gold shape=diamond]
  quarantine [label="quarantine_engaged\nbit 30" style=filled fillcolor=orange]
  emergency_node [label="emergency_mode\nbit 31" style=filled fillcolor=red fontcolor=white]
  dag_valid -> quarantine [style=dashed label="violation"]
  quarantine -> emergency_node [style=dashed label="escalate"]
}
