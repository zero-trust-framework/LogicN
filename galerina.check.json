{
  "_comment": "galerina.check.json — project-level configuration for `galerina check`",
  "_docs": "docs/Knowledge-Bases/galerina-check-config.md",

  "profile": "production",

  "rules": {
    "FUNGI-TAINT-001": "error",
    "FUNGI-TAINT-003": "error",
    "FUNGI-TAINT-004": "warning",
    "FUNGI-TAINT-005": "error",
    "FUNGI-TAINT-006": "error",

    "FUNGI-PROFILE-001": "error",
    "FUNGI-PROFILE-002": "error",
    "FUNGI-PROFILE-005B": "error",
    "FUNGI-PROFILE-006": "warning",

    "FUNGI-VAL-001": "error",
    "FUNGI-VAL-002": "error",

    "FUNGI-GOV-002": "error",
    "FUNGI-GOV-009": "error",

    "FUNGI-SYNTAX-010": "error",
    "FUNGI-SYNTAX-LEGACY-001": "error",
    "FUNGI-SYNTAX-LEGACY-002": "warning",

    "FUNGI-STYLE-001": "off",

    "FUNGI-SOURCE-ESCAPE-001": "error",
    "FUNGI-SEC-020": "error",
    "FUNGI-SEC-021": "error"
  },

  "ignore": [
    "tests/**",
    "examples/**",
    "docs/**"
  ],

  "minSeverity": "warning",

  "security": false,
  "flowgraph": false,

  "_note": "Set security:true and flowgraph:true to enable @galerina/devtools-security and @galerina/devtools-flowgraph integration (adds ~2s per file). Recommended for CI but slow for local checks."
}
