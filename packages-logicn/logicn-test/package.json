{
  "name": "@logicn/test",
  "version": "1.0.0-beta.2",
  "description": "The consolidated LogicN test harness — one named, consumable package that runs unit, e2e, conformance (R6) and fidelity-differential (walker ≡ bytecode ≡ WASM) checks against a LogicN workspace.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "bin": {
    "logicn-test": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0"
  },
  "private": true
}
