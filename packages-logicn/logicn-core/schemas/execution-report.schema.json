{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/execution-report.schema.json",
  "title": "LogicN Execution Report Prototype",
  "type": "object",
  "required": [
    "compiler",
    "project",
    "runtime",
    "compileMode",
    "modes",
    "runModeChecks",
    "compileModeOutputs",
    "productionRule",
    "aiGuideRule"
  ],
  "properties": {
    "compiler": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "required": [
        "runMode",
        "cacheIr",
        "hotReload"
      ],
      "properties": {
        "runMode": {
          "type": "string"
        },
        "cacheIr": {
          "type": "boolean"
        },
        "hotReload": {
          "type": "boolean"
        }
      }
    },
    "compileMode": {
      "type": "object"
    },
    "modes": {
      "type": "array"
    },
    "runModeChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compileModeOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "productionRule": {
      "type": "string"
    },
    "aiGuideRule": {
      "type": "string"
    }
  }
}