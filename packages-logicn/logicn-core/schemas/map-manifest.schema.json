{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/map-manifest.schema.json",
  "title": "LogicN Map Manifest Prototype",
  "type": "object",
  "required": [
    "project",
    "version",
    "compiler",
    "outputs",
    "sourceFiles",
    "routes",
    "webhooks",
    "types",
    "generatedDocumentation"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "compiler": {
      "type": "string"
    },
    "buildMode": {
      "type": "string"
    },
    "entry": {
      "type": "string"
    },
    "applicationEntry": {
      "type": [
        "string",
        "null"
      ]
    },
    "outputs": {
      "type": "object"
    },
    "sourceFiles": {
      "type": "array"
    },
    "routes": {
      "type": "array"
    },
    "webhooks": {
      "type": "array"
    },
    "types": {
      "type": "array"
    },
    "globals": {
      "type": "array"
    },
    "flows": {
      "type": "array"
    },
    "computeBlocks": {
      "type": "array"
    },
    "generatedDocumentation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime": {
      "type": "object"
    },
    "memoryPolicy": {
      "type": "object"
    },
    "executionPolicy": {
      "type": "object"
    },
    "globalRegistry": {
      "type": "object"
    },
    "aiGuide": {
      "type": "object"
    },
    "sourceMaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceHash": {
      "type": "string"
    }
  }
}