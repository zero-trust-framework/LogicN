{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/tokens.schema.json",
  "title": "LogicN Token Report Prototype",
  "type": "object",
  "required": [
    "compiler",
    "project",
    "files",
    "tokenCount",
    "tokens"
  ],
  "properties": {
    "compiler": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tokenCount": {
      "type": "integer",
      "minimum": 0
    },
    "tokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/token"
      }
    }
  },
  "$defs": {
    "token": {
      "type": "object",
      "required": [
        "type",
        "value",
        "file",
        "line",
        "column",
        "offset",
        "length"
      ],
      "properties": {
        "type": {
          "enum": [
            "boolean",
            "comment",
            "decimal",
            "docComment",
            "duration",
            "eof",
            "httpMethod",
            "identifier",
            "integer",
            "keyword",
            "newline",
            "operator",
            "size",
            "string",
            "symbol",
            "typeIdentifier"
          ]
        },
        "value": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        },
        "length": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}