{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/source-map.schema.json",
  "title": "LogicN Source Map Prototype",
  "type": "object",
  "required": [
    "version",
    "compiler",
    "project",
    "files",
    "symbols"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "compiler": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "files": {
      "type": "array"
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "name",
          "file",
          "line",
          "column"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "column": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}