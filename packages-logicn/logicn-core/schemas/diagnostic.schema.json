{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/diagnostic.schema.json",
  "title": "LogicN Standard Diagnostic",
  "type": "object",
  "required": [
    "code",
    "level",
    "category",
    "message",
    "source",
    "target",
    "recoveryAction",
    "timestamp"
  ],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^logicn-(INFO|WARN|ERR|FATAL)-[A-Z]+-[0-9]{3}$"
    },
    "level": {
      "enum": [
        "info",
        "warning",
        "error",
        "fatal"
      ]
    },
    "category": {
      "enum": [
        "memory",
        "disk",
        "cache",
        "logic",
        "target",
        "type",
        "null",
        "security",
        "environment",
        "io",
        "network",
        "api",
        "build",
        "runtime"
      ]
    },
    "message": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": [
        "file",
        "line"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "target": {
      "type": "string"
    },
    "recoveryAction": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "severity": {
      "enum": [
        "error",
        "warning",
        "info",
        "fatal"
      ]
    },
    "errorType": {
      "type": "string"
    },
    "file": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "column": {
      "type": "integer",
      "minimum": 1
    },
    "problem": {
      "type": "string"
    },
    "suggestedFix": {
      "type": "string"
    }
  }
}