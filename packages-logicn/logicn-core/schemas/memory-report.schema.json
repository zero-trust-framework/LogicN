{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/memory-report.schema.json",
  "title": "LogicN Memory Report Prototype",
  "type": "object",
  "required": [
    "compiler",
    "project",
    "summary",
    "runtimePolicy",
    "pressureLadder",
    "cacheLimit",
    "spillPolicy",
    "compileChecks",
    "recommendations",
    "generatedOutputs",
    "diagnostics"
  ],
  "properties": {
    "compiler": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "summary": {
      "type": "object"
    },
    "runtimePolicy": {
      "type": "object"
    },
    "pressureLadder": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "action",
          "behaviour"
        ],
        "properties": {
          "stage": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "behaviour": {
            "type": "string"
          }
        }
      }
    },
    "cacheLimit": {
      "type": "object"
    },
    "spillPolicy": {
      "type": "object"
    },
    "queueAndChannelPolicy": {
      "type": "object"
    },
    "jsonStreamPolicy": {
      "type": "object"
    },
    "compileChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "correctionFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exampleDiagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "level",
          "category",
          "message",
          "source",
          "target",
          "recoveryAction",
          "timestamp"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^logicn-(INFO|WARN|ERR|FATAL)-[A-Z]+-[0-9]{3}$"
          },
          "level": {
            "enum": [
              "info",
              "warning",
              "error",
              "fatal"
            ]
          },
          "category": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "source": {
            "type": "object"
          },
          "target": {
            "type": "string"
          },
          "recoveryAction": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generatedOutputs": {
      "type": "object"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "level",
          "category",
          "message",
          "source",
          "target",
          "recoveryAction",
          "timestamp"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^logicn-(INFO|WARN|ERR|FATAL)-[A-Z]+-[0-9]{3}$"
          },
          "level": {
            "enum": [
              "info",
              "warning",
              "error",
              "fatal"
            ]
          },
          "category": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "source": {
            "type": "object"
          },
          "target": {
            "type": "string"
          },
          "recoveryAction": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}