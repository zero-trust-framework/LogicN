{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://LogicN.local/schemas/ai-context.schema.json",
  "title": "LogicN AI Context Prototype",
  "type": "object",
  "required": [
    "compiler",
    "project",
    "summary",
    "sourceFiles",
    "changedFiles",
    "routeSummary",
    "webhookSummary",
    "typeSummary",
    "enumSummary",
    "flowSummary",
    "strictCommentSummary",
    "targets",
    "targetSummary",
    "runtimeSummary",
    "memorySummary",
    "executionSummary",
    "globalSummary",
    "securitySummary",
    "diagnostics",
    "nextActions"
  ],
  "properties": {
    "compiler": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "entry": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "sourceFileCount",
        "typeCount",
        "enumCount",
        "flowCount",
        "routeCount",
        "webhookCount",
        "diagnosticCount"
      ],
      "properties": {
        "sourceFileCount": {
          "type": "integer",
          "minimum": 0
        },
        "typeCount": {
          "type": "integer",
          "minimum": 0
        },
        "enumCount": {
          "type": "integer",
          "minimum": 0
        },
        "flowCount": {
          "type": "integer",
          "minimum": 0
        },
        "routeCount": {
          "type": "integer",
          "minimum": 0
        },
        "webhookCount": {
          "type": "integer",
          "minimum": 0
        },
        "diagnosticCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sourceFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "lines",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "lines": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "changedFiles": {
      "type": "object",
      "required": [
        "status",
        "files"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "files": {
          "type": "array"
        }
      }
    },
    "routeSummary": {
      "type": "array"
    },
    "webhookSummary": {
      "type": "array"
    },
    "typeSummary": {
      "type": "array"
    },
    "enumSummary": {
      "type": "array"
    },
    "flowSummary": {
      "type": "array"
    },
    "strictCommentSummary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "line",
          "subject",
          "tags"
        ],
        "properties": {
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "subject": {
            "type": [
              "object",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "purpose": {
            "type": [
              "string",
              "null"
            ]
          },
          "security": {
            "type": [
              "string",
              "null"
            ]
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aiNote": {
            "type": [
              "string",
              "null"
            ]
          },
          "aiRisk": {
            "type": [
              "string",
              "null"
            ]
          },
          "aiTodo": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targetSummary": {
      "type": "object"
    },
    "runtimeSummary": {
      "type": "object"
    },
    "memorySummary": {
      "type": "object"
    },
    "executionSummary": {
      "type": "object"
    },
    "globalSummary": {
      "type": "object"
    },
    "securitySummary": {
      "type": "object"
    },
    "diagnostics": {
      "type": "array"
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}