# LO / Logic Omni
# Git ignore rules for LO language projects and LO applications.
#
# Principle:
# - Commit source, docs, examples and safe config templates.
# - Do not commit secrets, local environment files, caches or generated build artefacts by default.

# ------------------------------------------------------------
# Environment / Secrets
# ------------------------------------------------------------

.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.staging.local
.env.production
.env.production.local

*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

# Keep the safe example file.
!.env.example

# ------------------------------------------------------------
# LO Build Output
# ------------------------------------------------------------

build/
.build-dev/
.build-dev-*/
dist/
out/
target/

*.bin
*.wasm
*.gpu.plan
*.photonic.plan
*.ternary.sim

*.target-report.json
*.security-report.json
*.failure-report.json
*.api-report.json
*.global-report.json
*.runtime-report.json
*.memory-report.json
*.execution-report.json
*.source-map.json
*.ai-context.json
*.build-manifest.json
*.openapi.json

# Generated schemas
generated/
.gen/

# ------------------------------------------------------------
# LO Runtime / Local Storage
# ------------------------------------------------------------

storage/logs/
storage/cache/
storage/tmp/
storage/temp/
storage/dead/
storage/sessions/

*.log
*.jsonl
*.tmp
*.temp
*.cache

# Keep storage folders if needed.
!storage/.gitkeep
!storage/logs/.gitkeep
!storage/cache/.gitkeep
!storage/dead/.gitkeep

# ------------------------------------------------------------
# LO Package / Dependency State
# ------------------------------------------------------------

packages/.cache/
vendor/.cache/

# Keep lockfile committed for reproducible builds.
!LO.lock

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Editor / IDE Files
# ------------------------------------------------------------

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

.idea/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# Node / JavaScript Tooling
# ------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/
.yarn/
.yarn-cache/

# ------------------------------------------------------------
# Python Tooling
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ------------------------------------------------------------
# Rust Tooling
# ------------------------------------------------------------

/target/
Cargo.lock

# For applications, Cargo.lock is usually committed.
# For a reusable Rust library/compiler crate, this may be ignored.
# Review this rule if the LO compiler is written in Rust.

# ------------------------------------------------------------
# Go Tooling
# ------------------------------------------------------------

bin/
pkg/
*.test
coverage.out

# ------------------------------------------------------------
# C / C++ / Native Build Output
# ------------------------------------------------------------

*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.out

cmake-build-*/
CMakeFiles/
CMakeCache.txt
Makefile

# ------------------------------------------------------------
# Java / JVM Tooling
# ------------------------------------------------------------

.gradle/
build/
*.class
*.jar
*.war
*.ear

# ------------------------------------------------------------
# .NET Tooling
# ------------------------------------------------------------

bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# ------------------------------------------------------------
# Test / Coverage Output
# ------------------------------------------------------------

coverage/
.coverage
lcov.info
test-results/
reports/
junit.xml

# ------------------------------------------------------------
# Local Databases
# ------------------------------------------------------------

*.sqlite
*.sqlite3
*.db
*.db-journal

# ------------------------------------------------------------
# Docker / Local Runtime
# ------------------------------------------------------------

.docker/
docker-compose.override.yml

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------

*.swp
*.swo
*~
.tmp/
temp/
.cache/

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
#
# Commit:
#
# - .lo source files
# - boot.lo
# - LO.config
# - LO.lock
# - .env.example
# - documentation
# - examples
# - tests
#
# Do not commit by default:
#
# - .env files
# - real secrets
# - generated build outputs
# - local logs
# - local caches
# - source maps from production builds unless intentionally stored securely
#
# LO rule:
#
#   Source belongs in Git.
#   Secrets stay outside Git.
#   Build artefacts are generated unless explicitly released.
