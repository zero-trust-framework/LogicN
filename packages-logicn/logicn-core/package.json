{
  "name": "@logicn/core",
  "version": "1.0.0-beta.2",
  "description": "LogicN / LogicN language package, examples, schemas and prototype CLI.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "LogicN": "./compiler/logicn.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.json",
    "check": "node compiler/logicn.js check examples --exclude source-map-error.lln",
    "build:examples": "node compiler/logicn.js build examples --exclude source-map-error.lln --out build/examples",
    "ast": "node compiler/logicn.js ast examples/hello.lln",
    "tokens": "node compiler/logicn.js tokens examples/hello.lln",
    "fmt": "node compiler/logicn.js fmt examples",
    "fmt:check": "node compiler/logicn.js fmt examples --check",
    "test": "node compiler/logicn.js test examples && npm run build:types && node --test tests/*.test.mjs",
    "generate:dev": "node compiler/logicn.js generate examples --exclude source-map-error.lln --out .build-dev",
    "dev": "node compiler/logicn.js dev examples/hello.lln --out .build-dev",
    "schema": "node compiler/logicn.js schema examples/api-orders.lln --type CreateOrderRequest",
    "openapi": "node compiler/logicn.js openapi examples/api-orders.lln",
    "verify": "node compiler/logicn.js verify build/examples",
    "targets": "node compiler/logicn.js targets examples",
    "ai-context": "node compiler/logicn.js ai-context examples --out build/examples"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
