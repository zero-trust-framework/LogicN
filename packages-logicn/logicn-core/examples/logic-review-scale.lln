enum ReviewScale {
  Reject
  Escalate
  Approve
  Audit
}

secure flow reviewScaleDecision(score: Decision) -> ReviewScale {
  contract {
    intent {
      "Map a governed order decision onto the review-scale outcome."
    }
  }
  match score {
    Deny   => Reject
    Review => Escalate
    Allow  => Approve
    _      => Reject
  }
}
