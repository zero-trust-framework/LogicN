# LogicN / LogicN
# Example environment file.
#
# Copy this file to `.env` for local development:
#
#   cp .env.example .env
#
# Never commit real `.env` files.
# Never put production secrets in this example file.
# Runtime configuration should stay outside compiled LogicN outputs.

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_NAME=LODemo
APP_ENV=local
APP_DEBUG=true
APP_PORT=8080
APP_HOST=127.0.0.1
APP_URL=http://localhost:8080

# ------------------------------------------------------------
# Build / Runtime Mode
# ------------------------------------------------------------

LogicN_BUILD_MODE=debug
LogicN_TARGETS=binary,wasm,gpu-plan,photonic-plan,ternary-sim
LogicN_SOURCE_MAPS=true
LogicN_AI_CONTEXT=true
LogicN_REPORTS=true

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------

# Generate a real secure value for local development.
# Do not use this placeholder in production.
APP_KEY=

# Used for signing internal application data where required.
APP_SIGNING_SECRET=

# Used for encrypting local development data where required.
APP_ENCRYPTION_KEY=

# ------------------------------------------------------------
# API
# ------------------------------------------------------------

API_BASE_URL=http://localhost:8080
API_TIMEOUT_SECONDS=5
API_MAX_BODY_SIZE=1mb
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=1m

# ------------------------------------------------------------
# Webhooks
# ------------------------------------------------------------

WEBHOOK_SECRET=
WEBHOOK_MAX_AGE=5m
WEBHOOK_MAX_BODY_SIZE=512kb
WEBHOOK_REPLAY_PROTECTION=true
WEBHOOK_IDEMPOTENCY=true

# Example payment webhook secret.
PAYMENT_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Example only.
# Replace with your local development database connection.
DATABASE_URL=

# Optional separate read/write database URLs.
DATABASE_READ_URL=
DATABASE_WRITE_URL=

# ------------------------------------------------------------
# Cache / Queue
# ------------------------------------------------------------

CACHE_URL=
QUEUE_URL=

# Example local dead-letter queue path.
DEAD_LETTER_PATH=./storage/dead

# ------------------------------------------------------------
# External Services
# ------------------------------------------------------------

PAYMENTS_API_URL=
PAYMENTS_API_KEY=

CUSTOMERS_API_URL=
CUSTOMERS_API_KEY=

STOCK_API_URL=
STOCK_API_KEY=

RISK_API_URL=
RISK_API_KEY=

# ------------------------------------------------------------
# AI / Model Services
# ------------------------------------------------------------

AI_PROVIDER=
AI_API_URL=
AI_API_KEY=
AI_MODEL_NAME=

# ------------------------------------------------------------
# GPU / Accelerator Planning
# ------------------------------------------------------------

GPU_ENABLED=false
GPU_PROVIDER=
GPU_DEVICE=
GPU_MEMORY_LIMIT=

PHOTONIC_ENABLED=false
PHOTONIC_PROVIDER=
PHOTONIC_MODE=plan

TERNARY_SIM_ENABLED=true

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

LOG_LEVEL=debug
LOG_FORMAT=json
LOG_REDACT_SECRETS=true

# ------------------------------------------------------------
# Source Maps
# ------------------------------------------------------------

SOURCE_MAPS_ENABLED=true
SOURCE_MAPS_PATH=./build/debug/app.source-map.json

# In production, source maps should normally be stored securely
# and not exposed publicly.
SOURCE_MAPS_PUBLIC=false

# ------------------------------------------------------------
# AI Context
# ------------------------------------------------------------

AI_CONTEXT_ENABLED=true
AI_CONTEXT_PATH=./build/debug/app.ai-context.json
AI_CONTEXT_REDACT_SECRETS=true

# ------------------------------------------------------------
# Deployment
# ------------------------------------------------------------

DEPLOY_ENV=local
BUILD_MANIFEST_PATH=./build/debug/app.build-manifest.json
HEALTH_CHECK_PATH=/health

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
#
# Real secrets should be provided by:
#
# - local `.env` files for development
# - server environment variables
# - container secrets
# - cloud secrets managers
# - deployment platform secrets
#
# Do not compile these values into:
#
# - app.bin
# - app.wasm
# - app.gpu.plan
# - app.photonic.plan
#
# LogicN rule:
#
#   Compiled files are not secret.
#   Secrets live outside compiled files.