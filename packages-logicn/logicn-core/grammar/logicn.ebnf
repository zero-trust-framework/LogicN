# LogicN Prototype Grammar Draft

This is a v0.1 grammar draft for the documented LogicN subset. It is intentionally
small enough for a prototype parser while preserving the important constraints:
strict typing, explicit errors, explicit missing values, CPU fallback and
accelerator planning.

```ebnf
program          = { comment | declaration } ;
declaration      = project_decl | language_decl | entry_decl | imports_block
                 | security_block | permissions_block | globals_block | targets_block
                 | json_policy_block | runtime_block | documentation_block
                 | ai_guide_block | manifests_block | build_block
                 | type_decl | enum_decl
                 | flow_decl | api_decl | webhook_decl | compute_block ;
comment          = normal_comment | doc_comment | strict_comment ;
normal_comment   = "//" { ? any character except newline ? } ;
doc_comment      = "///" { ? any character except newline ? } ;
strict_comment   = "///" "@" strict_tag { ? any character except newline ? } ;
strict_tag       = "purpose" | "summary" | "input" | "output" | "errors"
                 | "security" | "effects" | "permissions" | "target"
                 | "fallback" | "rollback" | "rollback-risk" | "route"
                 | "idempotency" | "timeout" | "max-body-size"
                 | "json-policy" | "ai-note"
                 | "ai-risk" | "ai-todo" | "test" | "owner"
                 | "since" | "source" | "verify" | "precision" | "request"
                 | "response" ;

project_decl     = "project" string ;
language_decl    = "language" block ;
entry_decl       = "entry" string ;

imports_block    = "imports" "{" { "use" module_name } "}" ;
module_name      = identifier { "." identifier } ;

type_decl        = "type" type_name "{" { field_decl } "}"
                 | "type" type_name "=" type_ref ;
field_decl       = identifier ":" type_ref ;

enum_decl        = "enum" type_name "{" { enum_case } "}" ;
enum_case        = type_name [ "(" parameters ")" ] ;

flow_decl        = [ flow_qualifier ] "flow" identifier
                   "(" [ parameters ] ")" "->" type_ref
                   [ effects_decl ] block [ rollback_block ] ;
flow_qualifier   = "secure" | "pure" ;
parameters       = parameter { "," parameter } ;
parameter        = identifier ":" type_ref ;
effects_decl     = "effects" "[" effect_name { "," effect_name } "]" ;
effect_name      = identifier { "." identifier } ;

api_decl         = "api" type_name "{" { route_decl } "}" ;
route_decl       = http_method string "{"
                   [ params_block ]
                   [ "request" type_ref ]
                   [ "response" type_ref ]
                   [ "errors" "[" type_ref { "," type_ref } "]" ]
                   [ "timeout" duration ]
                   [ "max_body_size" size ]
                   "handler" identifier
                   "}" ;
http_method      = "GET" | "POST" | "PUT" | "PATCH" | "DELETE" ;

webhook_decl     = "webhook" type_name "{"
                   "path" string
                   "method" http_method
                   "security" "{"
                     "hmac_header" string
                     "secret" env_secret
                     "max_age" duration
                     "max_body_size" size
                     "replay_protection" boolean
                   "}"
                   "idempotency_key" expression
                   "handler" identifier
                   "}" ;

compute_block    = "compute" "target" compute_target "{"
                   [ "prefer" compute_target ]
                   { "fallback" compute_target }
                   { statement }
                   "}" ;
compute_target   = "best" | "cpu" | "binary" | "wasm" | "gpu" | "photonic" | "ternary" ;

targets_block    = "targets" "{" { target_block } "}" ;
target_block     = compute_target "{" { setting } "}" ;

runtime_block    = "runtime" "{"
                   [ "run_mode" string | "run_mode" identifier ]
                   [ "cache_ir" boolean ]
                   [ "hot_reload" boolean ]
                   [ memory_block ]
                   "}" ;
memory_block     = "memory" "{"
                   [ "soft_limit" size ]
                   [ "hard_limit" size ]
                   [ "on_pressure" "[" { string } "]" ]
                   [ spill_block ]
                   "}" ;
spill_block      = "spill" "{"
                   [ "enabled" boolean ]
                   [ "path" string ]
                   [ "max_disk" size ]
                   [ "ttl" duration ]
                   [ "encryption" boolean ]
                   [ "redact_secrets" boolean ]
                   [ "aLOw" "[" { string } "]" ]
                   [ "deny" "[" { string } "]" ]
                   "}" ;
documentation_block = "documentation" "{"
                   "enabled" boolean
                   "required" boolean
                   "output" string
                   [ string_list_setting ]
                   [ "rules" "{" { setting } "}" ]
                   "}" ;
ai_guide_block   = "ai_guide" "{"
                   "enabled" boolean
                   [ "update_on_successful_compile" boolean ]
                   [ "output" string ]
                   [ "json_output" string ]
                   [ "include" "[" { string } "]" ]
                   [ "rules" "{" { setting } "}" ]
                   "}" ;
manifests_block  = "manifests" "{" { manifest_block } "}" ;
manifest_block   = identifier "{"
                   "required" boolean
                   "output" string
                   "}" ;
build_block      = "build" "{"
                   [ "mode" string ]
                   [ "deterministic" boolean ]
                   [ "source_maps" boolean ]
                   [ "reports" boolean ]
                   [ "map_manifest" boolean ]
                   [ "ai_context" boolean ]
                   [ "ai_guide" boolean ]
                   [ "documentation" boolean ]
                   [ "require_outputs" "[" { string } "]" ]
                   [ "fail_on_missing_output" boolean ]
                   [ "fail_on_doc_error" boolean ]
                   "}" ;
security_block   = "security" "{" { setting } "}" ;
permissions_block = "permissions" "{" { setting } "}" ;
globals_block   = "globals" "{" { global_decl | global_state } "}" ;
global_decl     = ("const" | "config" | "secret") identifier ":" type_ref "=" expression ;
global_state    = "state" identifier ":" type_ref "{" { setting } "}" ;
json_policy_block = "json_policy" "{" { setting } "}" ;
string_list_setting = identifier "[" { string } "]" ;

statement        = let_stmt | mut_stmt | return_stmt | match_stmt | if_stmt
                 | for_stmt | while_stmt | wait_until_stmt | expression ;
let_stmt         = "let" identifier ":" type_ref "=" expression ;
mut_stmt         = "mut" identifier ":" type_ref "=" expression ;
return_stmt      = "return" expression ;

type_ref         = type_name [ "<" type_ref { "," type_ref } ">" ] ;
identifier       = ? lower or mixed case identifier ? ;
type_name        = ? upper case identifier ? ;
string           = ? double quoted UTF-8 string ? ;
boolean          = "true" | "false" ;
duration         = integer ( "ms" | "s" | "m" | "h" | "d" ) ;
size             = integer ( "b" | "kb" | "mb" | "gb" ) ;
```

## Compatibility Rule

Every implementation must treat CPU or binary output as the compatibility
baseline. GPU, photonic and ternary targets may be emitted as plans or
simulations until real backends exist.

## Token Classes

The prototype lexer emits these token classes:

```text
keyword
identifier
typeIdentifier
httpMethod
string
integer
decimal
duration
size
boolean
symbol
operator
comment
docComment
newline
eof
```

The parser may ignore comments and newlines where they are not syntactically
significant, but the token stream keeps them for future formatting and
source-map work.

`///` lines are documentation comments. `/// @tag value` lines are strict
comments. The v0.1 prototype extracts strict comments into AI context and
source maps, and reports obvious mismatches as warnings.

## Formatting Baseline

The prototype formatter uses:

```text
two-space indentation
opening brace on the same line
one blank line at most between source blocks
trimmed trailing whitespace
one final newline
```

It is intentionally conservative and line-based. Later versions should format
from the parser AST once the grammar stabilises.
