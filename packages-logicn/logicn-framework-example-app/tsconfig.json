{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "host",
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["../logicn-tower-citizen/node_modules/@types"]
  },
  "include": ["host/**/*.ts"]
}
