// EXPECT: ACCEPT
// R6 corpus 001 — R1: strings + Result + contract.types
pure flow classify(score: Int) -> Verdict
contract {
  types {
    type Verdict = Result<String, String>
  }
  intent { "Classify a score, returning Ok(label) or Err(reason)." }
}
{
  if score < 0 {
    return Err("negative")
  }
  if score >= 50 {
    return Ok("pass")
  }
  return Ok("fail")
}
