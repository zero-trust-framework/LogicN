{
  "name": "@logicn/core-logic",
  "version": "1.0.0-beta.2",
  "description": "LogicN multi-state logic concepts including Tri, Decision, BoolBoundary and Omni logic.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tri": {
      "import": "./dist/tri/index.js",
      "types": "./dist/tri/index.d.ts"
    },
    "./decision": {
      "import": "./dist/decision/index.js",
      "types": "./dist/decision/index.d.ts"
    },
    "./bool-boundary": {
      "import": "./dist/bool-boundary/index.js",
      "types": "./dist/bool-boundary/index.d.ts"
    },
    "./omni": {
      "import": "./dist/omni/index.js",
      "types": "./dist/omni/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "npm run typecheck && npm run build && node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
