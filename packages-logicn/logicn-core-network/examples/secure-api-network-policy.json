{
  "name": "secure-api",
  "defaultEffect": "deny",
  "tls": {
    "requireTls": true,
    "minVersion": "TLS1.3",
    "verifyCertificates": true,
    "verifyHostnames": true,
    "denySelfSignedInProduction": true,
    "allowPlaintextFallback": false,
    "allowDowngrade": false
  },
  "endpoints": [
    {
      "direction": "inbound",
      "protocol": "https",
      "effect": "allow",
      "ports": [443],
      "reason": "Public API entry point"
    },
    {
      "direction": "outbound",
      "protocol": "https",
      "effect": "allow",
      "hosts": ["payments.internal.example"],
      "reason": "Payment service call"
    }
  ],
  "rateLimits": [
    {
      "name": "login",
      "limit": "5/minute",
      "scope": "ip"
    }
  ],
  "privacy": {
    "minimiseMetadata": true,
    "denyQueryStringSecrets": true,
    "redactSensitiveHeaders": true,
    "denySensitiveDataInUrls": true
  },
  "denyRawSockets": true,
  "requireTimeouts": true,
  "requireBackpressure": true
}
