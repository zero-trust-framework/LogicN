{
  "benchmarkId": "toxic-input",
  "description": "Every toxic call must produce a trap AuditEvent; valid calls must produce none.",
  "requiredEventFields": ["event", "flow", "trapKind", "rollbackStatus", "timestamp"],
  "scenarios": {
    "negative-amount (toxic)": {
      "flow": "processPayment",
      "args": [-1, "USD"],
      "expectTrap": true,
      "expectedTrapKind": "ERR_NEGATIVE_AMOUNT",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000"
    },
    "zero-amount (toxic)": {
      "flow": "processPayment",
      "args": [0, "GBP"],
      "expectTrap": true,
      "expectedTrapKind": "ERR_NEGATIVE_AMOUNT",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000"
    },
    "over-limit (toxic)": {
      "flow": "processPayment",
      "args": [9999999, "EUR"],
      "expectTrap": true,
      "expectedTrapKind": "ERR_AMOUNT_EXCEEDS_LIMIT",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000"
    },
    "empty-currency (toxic)": {
      "flow": "processPayment",
      "args": [100, ""],
      "expectTrap": true,
      "expectedTrapKind": "ERR_EMPTY_CURRENCY",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000"
    },
    "valid input (baseline)": {
      "flow": "processPaymentValid",
      "args": [500, "USD"],
      "expectTrap": false,
      "expectedResult": "Ok(true)"
    }
  },
  "complianceChecks": {
    "allToxicCallsMustTrap": true,
    "rollbackAlwaysClean": true,
    "auditEventForEveryTrap": true
  }
}
