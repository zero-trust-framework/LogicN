{
  "benchmarkId": "governance-violation",
  "description": "Forbidden userIds (guest, anonymous) must be denied; authorised user must succeed.",
  "requiredEventFields": ["event", "flow", "trapKind", "rollbackStatus", "timestamp"],
  "scenarios": {
    "guest write (denied)": {
      "flow": "attemptUnauthorisedWrite",
      "args": ["guest", "data"],
      "expectTrap": true,
      "expectedTrapKind": "ERR_GUEST_WRITE_DENIED",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000",
      "note": "Simulates V_DPM capability denial for guest role"
    },
    "anonymous write (denied)": {
      "flow": "attemptUnauthorisedWrite",
      "args": ["anonymous", "data"],
      "expectTrap": true,
      "expectedTrapKind": "ERR_ANONYMOUS_DENIED",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "LLN-INV-000",
      "note": "Simulates V_DPM capability denial for anonymous role"
    },
    "authorised write (ok)": {
      "flow": "authorisedWrite",
      "args": ["alice", "data"],
      "expectTrap": false,
      "expectedResult": "Ok(true)"
    }
  },
  "complianceChecks": {
    "forbiddenRolesMustBeDenied": true,
    "rollbackAlwaysClean": true,
    "vdpmSimulationFires": true
  }
}
