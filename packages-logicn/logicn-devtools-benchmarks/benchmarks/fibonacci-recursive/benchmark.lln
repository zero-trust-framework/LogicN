/// fibonacci-recursive benchmark — LogicN governed runtime
/// Naive recursive Fibonacci — no memoization.
/// Tests recursive flow call overhead (each call allocates a stack frame + tagged values).
/// Uses fib(20) to keep wall time reasonable; runner reports extrapolated throughput.

pure flow fib(n: Int) -> Int
contract { effects {} }
{
  if n <= 1 {
    return n
  }
  return fib(n - 1) + fib(n - 2)
}

pure flow main() -> Int
contract { effects {} }
{
  return fib(20)
}
