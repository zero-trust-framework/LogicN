{
  "name": "@logicn/devtools-benchmarks",
  "version": "0.1.0",
  "description": "Runtime comparison benchmarks: Python · Node.js · C++ · Rust · LogicN (governed + manifest)",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "run":                    "node src/runner.mjs",
    "run:quick":              "node src/runner.mjs --quick",
    "run:compute-mix":        "node src/runner.mjs --benchmark compute-mix",
    "run:arithmetic":         "node src/runner.mjs --benchmark arithmetic-threshold",
    "run:guess":              "node src/runner.mjs --benchmark six-digit-guess",
    "run:hardware-targets":   "node src/runner.mjs --benchmark hardware-targets",
    "run:governance-cost":    "node src/runner.mjs --benchmark governance-cost",
    "run:call-chain":         "node src/runner.mjs --benchmark call-chain",
    "run:passive":            "node src/runner.mjs --benchmark hardware-targets",
    "run:http":               "node benchmarks/http-throughput/benchmark.mjs",
    "compare":                "node src/compare.mjs",
    "build:native":           "node src/build-native.mjs",
    "bench":                  "node src/runner.mjs --quick && node src/compare.mjs",
    "run:diagnostic":         "node src/diagnostic-runner.mjs",
    "run:diagnostic-suite":   "node src/runner.mjs --diagnostic",
    "run:fault-injection":    "node src/diagnostic-runner.mjs --benchmark toxic-input --benchmark governance-violation"
  },
  "dependencies": {
    "@logicn/core-compiler": "file:../logicn-core-compiler"
  },
  "engines": { "node": ">=18" }
}
