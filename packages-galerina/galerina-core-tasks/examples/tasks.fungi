task generateReports {
  effects [filesystem, reports]

  permissions {
    write "./build/reports"
  }

  run {
    reports.generateSecurity()
    reports.generateMemory()
    reports.generateRoutes()
  }
}

task buildApi {
  depends [generateReports]
  effects [filesystem, compiler, reports]

  permissions {
    read "./src"
    write "./build"
  }

  run {
    compiler.check()
    compiler.build()
    reports.generate()
  }
}
