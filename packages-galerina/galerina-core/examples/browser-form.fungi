project "BrowserFormDemo"

target browser {
  output js
  wasm optional
  fallback js
  source_maps true
}

capabilities {
  allow dom
  allow fetch
  allow storage

  block environment
  block filesystem
  block server_database
  block secrets
  block native_bindings
}

import browser.dom
import browser.http

type ContactFormData {
  name: String
  email: String
  message: String
}

secure flow main() -> Result<Void, Error> {
  return Ok()
}
