// EXPECT: ACCEPT
// AREA: api
// PURPOSE: checkpoint and rollback for transactional flows
type Order {
  id: String
}

enum OrderError {
  PaymentFailed
  StockUnavailable
}

secure flow completeOrder(order: Order) -> Result<Order, OrderError> {
  checkpoint beforeOrderComplete

  reserveStock(order)
  takePayment(order)
  dispatchOrder(order)

  return Ok(order)

} rollback error {
  restore beforeOrderComplete
  releaseStock(order)
  refundPayment(order)

  return Err(error)
}
