{
  "name": "@galerinaa/devtools-benchmarks",
  "version": "1.0.0-beta.2",
  "description": "Runtime comparison benchmarks: Python · Node.js · C++ · Rust · Galerina (governed + manifest)",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "run":                    "node --expose-gc src/runner.mjs",
    "run:quick":              "node --expose-gc src/runner.mjs --quick",
    "run:compute-mix":        "node --expose-gc src/runner.mjs --benchmark compute-mix",
    "run:arithmetic":         "node --expose-gc src/runner.mjs --benchmark arithmetic-threshold",
    "run:guess":              "node --expose-gc src/runner.mjs --benchmark six-digit-guess",
    "run:hardware-targets":   "node --expose-gc src/runner.mjs --benchmark hardware-targets",
    "run:governance-cost":    "node --expose-gc src/runner.mjs --benchmark governance-cost",
    "run:call-chain":         "node --expose-gc src/runner.mjs --benchmark call-chain",
    "run:passive":            "node --expose-gc src/runner.mjs --benchmark hardware-targets",
    "run:http":               "node benchmarks/http-throughput/benchmark.mjs",
    "compare":                "node src/compare.mjs",
    "build:native":           "node src/build-native.mjs",
    "test":                   "node test/throughput-units.test.mjs",
    "audit":                  "node --expose-gc src/audit.mjs",
    "snapshot":               "node src/snapshot.mjs",
    "bench":                  "node --expose-gc src/runner.mjs --quick && node src/compare.mjs && node --expose-gc src/audit.mjs",
    "run:diagnostic":         "node src/diagnostic-runner.mjs",
    "run:diagnostic-suite":   "node --expose-gc src/runner.mjs --diagnostic",
    "run:fault-injection":    "node src/diagnostic-runner.mjs --benchmark toxic-input --benchmark governance-violation"
  },
  "dependencies": {
    "@galerinaa/core-compiler": "file:../galerina-core-compiler"
  },
  "engines": { "node": ">=18" }
}
