{
  "benchmarkId": "resource-exhaustion",
  "description": "Payloads and compute budgets beyond DWI ceilings must trap; boundary values must succeed.",
  "requiredEventFields": ["event", "flow", "trapKind", "rollbackStatus", "timestamp"],
  "scenarios": {
    "payload at ceiling (ok)": {
      "flow": "processAtCeiling",
      "args": [4096, 100],
      "expectTrap": false,
      "note": "4096 KB == DWI memory ceiling, must succeed"
    },
    "payload over ceiling": {
      "flow": "processLargePayload",
      "args": [5000, 100],
      "expectTrap": true,
      "expectedTrapKind": "ERR_PAYLOAD_EXCEEDS_DWI_CEILING",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "FUNGI-INV-000",
      "note": "Simulates DWI linear-memory exhaustion"
    },
    "compute over budget": {
      "flow": "processLargePayload",
      "args": [100, 20000],
      "expectTrap": true,
      "expectedTrapKind": "ERR_COMPUTE_BUDGET_EXCEEDED",
      "expectedRollbackStatus": "clean",
      "auditEventCode": "FUNGI-INV-000",
      "note": "Simulates Wasmtime fuel exhaustion"
    }
  },
  "complianceChecks": {
    "boundaryValuesMustSucceed": true,
    "overLimitMustTrap": true,
    "rollbackAlwaysClean": true
  }
}
