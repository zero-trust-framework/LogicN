/// collection-pipeline benchmark — LogicN governed runtime
/// filter(isEven) -> map(*2) -> sum over integers 0..9999
/// Implemented as a while loop because filter/map/reduce chaining
/// requires stdlib verification not yet available in governed mode.

pure flow main() -> Int
contract { effects {} }
{
  mut sum: Int = 0
  mut i:   Int = 0
  while i < 10000 {
    if i - (i / 2) * 2 == 0 {
      sum = sum + i * 2
    }
    i = i + 1
  }
  return sum
}
