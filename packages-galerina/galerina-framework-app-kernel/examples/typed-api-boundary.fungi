api OrdersApi {
  POST "/orders" {
    request CreateOrderRequest
    response CreateOrderResponse
    handler createOrder

    auth {
      bearer required
      scopes ["orders.write"]
    }

    body {
      content_type "application/json"
      max_size 256kb
      unknown_fields "deny"
    }

    idempotency {
      key header "Idempotency-Key"
      ttl 24h
      payload_mismatch "reject"
    }

    limits {
      rate "30/minute"
      max_concurrent 5
      memory 32mb
    }
  }
}
