;; emergency-sm.fungi — Emergency State Machine transitions
;; DRCM Phase 5.4 — DSS Supervisor Core (#41)
;;
;; The emergency state machine is pre-compiled — O(1) lookup, no branching logic.
;; DSS.wasm performs a lookup against the manifest's emergencyTransitionDecl nodes.
;; Zero Decision Entropy: no heuristics, no judgment — only manifest-authorized transitions.
;;
;; Build order position: 4b of 7

import "./vdpm.fungi"
import "./capability-map.fungi"

;; EmergencyTransitionResult — the output of applying an emergency transition
type EmergencyTransitionResult {
  vdpmAfter:        Int     ;; V_DPM register value after clearing bits
  bitsCleared:      Int     ;; bitmask of bits that were cleared
  quarantineSet:    Bool    ;; quarantine_engaged bit set?
  emergencyModeSet: Bool    ;; emergency_mode bit set?
  signalHandled:    Bool    ;; was a matching transition found?
}

;; Apply the circuit breaker transition:
;; Clears: network.outbound (bit 0), storage.write (bit 1), ai.inference (bit 5)
;; Leaves: secret.access, audit.write, database.write, shell.execute, native.call
pure flow applyCircuitBreaker(vdpm: Int) -> EmergencyTransitionResult
contract {
  intent "Circuit breaker: clear network, storage, AI capability bits"
  effects {}
}
{
  let clearMask = Int.bitOr(V_DPM.network_outbound, Int.bitOr(V_DPM.storage_write, V_DPM.ai_inference))
  let keepMask = Int.bitAnd(vdpm, 4294967260)  ;; ~(bit0 | bit1 | bit5) = ~35
  let newVdpm = Int.bitAnd(vdpm, keepMask)

  return EmergencyTransitionResult {
    vdpmAfter:        newVdpm
    bitsCleared:      clearMask
    quarantineSet:    false
    emergencyModeSet: false
    signalHandled:    true
  }
}

;; Apply quarantine transition:
;; Clears ALL capability bits (0-12), sets quarantine_engaged (bit 30)
pure flow applyQuarantine(vdpm: Int) -> EmergencyTransitionResult
contract {
  intent "Quarantine: clear all capabilities, set quarantine flag"
  effects {}
}
{
  ;; Clear bits 0-12, set bit 30 (quarantine_engaged = 1073741824)
  let cleared = Int.bitAnd(vdpm, 4286578688)  ;; keep bits 13-29 and 31
  let newVdpm = Int.bitOr(cleared, V_DPM.quarantine_engaged)

  return EmergencyTransitionResult {
    vdpmAfter:        newVdpm
    bitsCleared:      8191
    quarantineSet:    true
    emergencyModeSet: false
    signalHandled:    true
  }
}

;; Apply emergency mode transition:
;; Clears ALL capability bits (0-12), sets emergency_mode (bit 31)
pure flow applyEmergencyMode(vdpm: Int) -> EmergencyTransitionResult
contract {
  intent "Emergency mode: clear all capabilities, set emergency flag"
  effects {}
}
{
  let cleared = Int.bitAnd(vdpm, 4286578688)
  let newVdpm = Int.bitOr(cleared, V_DPM.emergency_mode)

  return EmergencyTransitionResult {
    vdpmAfter:        newVdpm
    bitsCleared:      8191
    quarantineSet:    false
    emergencyModeSet: true
    signalHandled:    true
  }
}
